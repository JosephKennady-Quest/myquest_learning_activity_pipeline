# ══════════════════════════════════════════════════════════════════════════════
#  AEL V2 Pipeline — Environment Variables
#  Copy this file to .env and fill in the values.
#  .env is gitignored — never commit it.
# ══════════════════════════════════════════════════════════════════════════════


# ── Source DB (quest_rearch_production) ───────────────────────────────────────

# Bastion / jump server
SOURCE_SSH_HOST=<bastion-ip>
SOURCE_SSH_PORT=22
SOURCE_SSH_USER=<ssh-username>
# Filename only — file must exist in DB_Config/
SOURCE_SSH_PKEY_FILE=joseph_prod.pem

# RDS endpoint (accessed through the tunnel)
SOURCE_RDS_HOST=<rds-endpoint>.rds.amazonaws.com
SOURCE_RDS_PORT=3306

# MySQL credentials
SOURCE_DB_USER=<db-username>
SOURCE_DB_PASSWORD=<db-password>
SOURCE_DB_NAME=quest_rearch_production


# ── Destination DB (analytics_) ───────────────────────────────────────────────

# Bastion / jump server
DEST_SSH_HOST=<bastion-ip>
DEST_SSH_PORT=22
DEST_SSH_USER=<ssh-username>
# Filename only — file must exist in DB_Config/
DEST_SSH_PKEY_FILE=analytics_master.pem

# RDS endpoint (accessed through the tunnel)
DEST_RDS_HOST=<rds-endpoint>.rds.amazonaws.com
DEST_RDS_PORT=3306

# MySQL credentials
DEST_DB_USER=<db-username>
# Wrap password in single quotes if it contains special characters like # or spaces
DEST_DB_PASSWORD='<db-password>'
DEST_DB_NAME=analytics_


# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
